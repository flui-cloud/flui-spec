              "items": {
                "type": "string"
              }
            },
            "envMapping": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "issuerUrl": {
                  "type": "string"
                },
                "clientId": {
                  "type": "string"
                },
                "clientSecret": {
                  "type": "string"
                },
                "enabledFlag": {
                  "type": "string"
                }
              }
            }
          }
        },
        "proxy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "headerMapping": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "smokeTest": {
      "type": "object",
