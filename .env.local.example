# Copy to .env.local and fill in. .env.local is gitignored.

# Token for the local self-hosted SonarQube instance running on port 9000
# (generate from http://localhost:9000 → My Account → Security → Generate token)
SONAR_TOKEN=

# Optional overrides for `pnpm sonar:scan`. Defaults shown.
# SONAR_HOST_URL=http://host.docker.internal:9000
# SONAR_PROJECT_KEY=FluiSpec
